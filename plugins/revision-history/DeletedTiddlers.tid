<$list filter="[all[tiddlers]has[revision-deleted]get[revision-of]unique[]!is[tiddler]]" variable="deletedName">

<<deletedName>>
<$reveal type="nomatch" state="$:/state/revision-history/restore-confirm" text=<<deletedName>>>
<$button>Restore<$action-setfield $tiddler="$:/state/revision-history/restore-confirm" $value=<<deletedName>>/></$button>
</$reveal>
<$reveal type="match" state="$:/state/revision-history/restore-confirm" text=<<deletedName>>>
Restore ''<<deletedName>>''?
<$button>Yes<$action-sendmessage $message="tm-restore-deleted-tiddler" tiddlerName=<<deletedName>>/><$action-navigate $to=<<deletedName>>/><$action-setfield $tiddler="$:/state/revision-history/restore-confirm" $value=""/></$button>
<$button>No<$action-setfield $tiddler="$:/state/revision-history/restore-confirm" $value=""/></$button>
</$reveal>
<br/>

</$list>
